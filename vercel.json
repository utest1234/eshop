{
    "builds": [
        {
            "src": "eshop/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb",
                "runtime": "python3.14.1"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "eshop/wsgi.py"
        }
    ],
    "installCommand": "bash build.sh"
}